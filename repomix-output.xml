<file path="src/components/RosterManager.tsx">
import { useState } from 'react'
import type { Character } from '../types'

const COLORS = [
  '#C3073F', '#4a7abf', '#5a9a5a', '#9a5abf',
  '#bf7a3a', '#3abfbf', '#bf3a7a', '#c9a84c',
]

interface RosterManagerProps {
  roster: Character[]
  onSave: (roster: Character[]) => void
  onBack: () => void
}

interface CharacterSheetProps {
  character: Character
  onSave: (char: Character) => void
  onBack: () => void
  isNew?: boolean
}

// ─── CHARACTER SHEET EDITOR ──────────────────────────────────────────────────

function CharacterSheet({ character, onSave, onBack, isNew = false }: CharacterSheetProps) {
  const [data, setData] = useState<Character>({
    appearance: '',
    personality: '',
    powers: '',
    backstory: '',
    ...character // Ensures older NPCs get the new empty fields safely
  })
  const [activeTab, setActiveTab] = useState<'info' | 'sheet'>('info')

  // ─── NEW: CUSTOM PALETTE PERSISTENCE STATE ───
  const [customColors, setCustomColors] = useState<string[]>(() => {
    try {
      const saved = localStorage.getItem('soul_custom_colors')
      return saved ? JSON.parse(saved) : []
    } catch {
      return []
    }
  })

  function update(field: keyof Character, value: string) {
    setData(prev => ({ ...prev, [field]: value }))
  }

  function handleAvatar(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0]
    if (!file) return
    const reader = new FileReader()
    reader.onload = ev => update('avatar', ev.target?.result as string)
    reader.readAsDataURL(file)
  }

  // ─── NEW PALETTE MUTATIONS ───
  function saveCurrentCustomColor() {
    if (customColors.includes(data.color)) return
    const updated = [...customColors, data.color].slice(-8) // Limit to the last 8 custom colors to keep it tidy
    setCustomColors(updated)
    localStorage.setItem('soul_custom_colors', JSON.stringify(updated))
  }

  function removeCustomColor(colorToRemove: string) {
    const updated = customColors.filter(c => c !== colorToRemove)
    setCustomColors(updated)
    localStorage.setItem('soul_custom_colors', JSON.stringify(updated))
  }

  return (
    <div style={{ display: 'flex', flexDirection: 'column', height: '100%', minHeight: '500px' }}>

      {/* Header Controls */}
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '20px', flexShrink: 0 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
          <button
            onClick={onBack}
            style={{
              background: 'transparent', border: '1px solid var(--border2)',
              color: 'var(--text2)', padding: '6px 12px',
              borderRadius: 'var(--radius)', fontFamily: 'Cinzel, serif',
              fontSize: '11px', letterSpacing: '1px', cursor: 'pointer',
            }}
          >
            ← BACK
          </button>
          <div style={{ fontFamily: 'Cinzel, serif', fontSize: '16px', color: 'var(--gold)', letterSpacing: '2px' }}>
            {isNew ? 'NEW CHARACTER' : 'EDIT CHARACTER'}
          </div>
        </div>

        {/* Tab Switcher */}
        <div style={{ display: 'flex', gap: '4px', background: 'var(--surface2)', padding: '3px', borderRadius: 'var(--radius)' }}>
          <button
            onClick={() => setActiveTab('info')}
            style={{
              padding: '6px 14px', borderRadius: '4px', border: 'none',
              background: activeTab === 'info' ? 'var(--gold-dim)' : 'transparent',
              color: activeTab === 'info' ? 'var(--gold)' : 'var(--text3)',
              fontFamily: 'Cinzel, serif', fontSize: '10px', letterSpacing: '1px', cursor: 'pointer', transition: 'all 0.15s'
            }}
          >
            GENERAL INFO
          </button>
          <button
            onClick={() => setActiveTab('sheet')}
            style={{
              padding: '6px 14px', borderRadius: '4px', border: 'none',
              background: activeTab === 'sheet' ? 'var(--gold-dim)' : 'transparent',
              color: activeTab === 'sheet' ? 'var(--gold)' : 'var(--text3)',
              fontFamily: 'Cinzel, serif', fontSize: '10px', letterSpacing: '1px', cursor: 'pointer', transition: 'all 0.15s'
            }}
          >
            CHARACTER SHEET
          </button>
        </div>
      </div>

      {/* Body Content wrapper */}
      <div style={{ flex: 1, overflowY: 'auto', paddingRight: '4px', marginBottom: '20px' }}>
        
        {/* Tab 1: General Info */}
        {activeTab === 'info' && (
          <div>
            <div style={{ display: 'flex', alignItems: 'center', gap: '20px', marginBottom: '24px' }}>
              <div
                onClick={() => document.getElementById('roster-avatar')?.click()}
                style={{
                  width: '90px', height: '90px', borderRadius: '50%',
                  background: data.avatar ? 'transparent' : 'var(--surface3)',
                  border: `2px ${data.avatar ? 'solid' : 'dashed'} var(--border2)`,
                  display: 'flex', alignItems: 'center', justifyContent: 'center',
                  cursor: 'pointer', flexShrink: 0, overflow: 'hidden',
                  transition: 'border-color 0.2s',
                }}
                onMouseEnter={e => (e.currentTarget.style.borderColor = 'var(--gold)')}
                onMouseLeave={e => (e.currentTarget.style.borderColor = 'var(--border2)')}
              >
                {data.avatar
                  ? <img src={data.avatar} style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                  : <span style={{ fontSize: '26px', color: 'var(--text3)' }}>+</span>
                }
              </div>
              <input type="file" id="roster-avatar" accept="image/*" style={{ display: 'none' }} onChange={handleAvatar} />
              <div style={{ flex: 1 }}>
                <FieldInput label="NAME" value={data.name} onChange={v => update('name', v)} placeholder="Character name" />
              </div>
            </div>

            <FieldInput label="ROLE / DESCRIPTION" value={data.role} onChange={v => update('role', v)} placeholder="e.g. Tavern Keep, Sith Lord, Companion..." />

            {/* ACCENT COLORS */}
            <div style={{ marginBottom: '20px' }}>
              <label style={{ fontFamily: 'Cinzel, serif', fontSize: '10px', color: 'var(--text2)', letterSpacing: '1.5px', display: 'block', marginBottom: '8px' }}>
                ACCENT COLOR
              </label>
              <div style={{ display: 'flex', gap: '10px', flexWrap: 'wrap', alignItems: 'center' }}>
                {/* 1. Preset Dots */}
                {COLORS.map(c => (
                  <div
                    key={c}
                    onClick={() => update('color', c)}
                    style={{
                      width: '28px', height: '28px', borderRadius: '50%',
                      background: c, cursor: 'pointer',
                      border: data.color === c ? '2px solid white' : '2px solid transparent',
                      transform: data.color === c ? 'scale(1.18)' : 'scale(1)',
                      transition: 'all 0.15s',
                    }}
                  />
                ))}

                {/* 2. CUSTOM RAINBOW COLOR PICKER DOT */}
                <div style={{ position: 'relative', width: '28px', height: '28px' }}>
                  <div
                    onClick={() => document.getElementById('custom-color-picker')?.click()}
                    style={{
                      width: '28px', height: '28px', borderRadius: '50%',
                      background: 'linear-gradient(45deg, #ff3b6f, #ff3b3b, #ffb33b, #3bff5e, #3b9aff, #b33bff)',
                      cursor: 'pointer',
                      border: !COLORS.includes(data.color) && !customColors.includes(data.color) ? '2px solid white' : '2px solid transparent',
                      transform: !COLORS.includes(data.color) && !customColors.includes(data.color) ? 'scale(1.18)' : 'scale(1)',
                      transition: 'all 0.15s',
                      display: 'flex', alignItems: 'center', justifyContent: 'center',
                      fontSize: '11px', textShadow: '0 1px 2px rgba(0,0,0,0.5)',
                    }}
                    title="Choose custom color"
                  >
                    🎨
                  </div>
                  <input
                    id="custom-color-picker"
                    type="color"
                    value={COLORS.includes(data.color) ? '#c9a84c' : data.color}
                    onChange={e => update('color', e.target.value)}
                    style={{
                      position: 'absolute', opacity: 0, width: 1, height: 1, pointerEvents: 'none'
                    }}
                  />
                </div>

                {/* 3. Custom color value hex preview */}
                {!COLORS.includes(data.color) && (
                  <span style={{
                    fontFamily: 'monospace', fontSize: '11px', color: 'var(--text3)',
                    background: 'var(--surface3)', padding: '3px 8px', borderRadius: '4px',
                    border: '1px solid var(--border)', letterSpacing: '0.5px'
                  }}>
                    {data.color.toUpperCase()}
                  </span>
                )}

                {/* 4. Save to Palette Button (Only displays if custom color is active and not already saved) */}
                {!COLORS.includes(data.color) && !customColors.includes(data.color) && (
                  <button
                    onClick={saveCurrentCustomColor}
                    style={{
                      background: 'transparent', border: '1px dashed var(--border2)',
                      color: 'var(--text2)', borderRadius: 'var(--radius)',
                      padding: '4px 10px', fontSize: '10px', fontFamily: 'Cinzel, serif',
                      cursor: 'pointer', display: 'flex', alignItems: 'center', gap: '4px',
                      transition: 'border-color 0.15s'
                    }}
                    onMouseEnter={e => e.currentTarget.style.borderColor = 'var(--gold)'}
                    onMouseLeave={e => e.currentTarget.style.borderColor = 'var(--border2)'}
                  >
                    + ADD TO PALETTE
                  </button>
                )}
              </div>

              {/* 5. CREATED COLORS ROW (Only shows up if you have saved custom colors!) */}
              {customColors.length > 0 && (
                <div style={{ marginTop: '16px' }}>
                  <div style={{ fontFamily: 'Cinzel, serif', fontSize: '9px', color: 'var(--text3)', letterSpacing: '1.5px', marginBottom: '8px' }}>
                    CREATED COLORS
                  </div>
                  <div style={{ display: 'flex', gap: '10px', flexWrap: 'wrap', alignItems: 'center' }}>
                    {customColors.map(c => (
                      <div
                        key={c}
                        onClick={() => update('color', c)}
                        style={{
                          width: '24px', height: '24px', borderRadius: '50%', // Slightly smaller to look secondary
                          background: c, cursor: 'pointer',
                          border: data.color === c ? '2px solid white' : '2px solid transparent',
                          transform: data.color === c ? 'scale(1.18)' : 'scale(1)',
                          transition: 'all 0.15s',
                          position: 'relative'
                        }}
                        title={c.toUpperCase()}
                      >
                        {/* Tiny delete x icon to clean up palette */}
                        <div
                          onClick={(e) => {
                            e.stopPropagation() // Prevent selecting the color on deletion
                            removeCustomColor(c)
                          }}
                          style={{
                            position: 'absolute', top: '-4px', right: '-4px',
                            background: 'rgba(0,0,0,0.85)', border: '1px solid rgba(255,255,255,0.1)',
                            color: 'var(--text3)', width: '12px', height: '12px', borderRadius: '50%',
                            fontSize: '8px', display: 'flex', alignItems: 'center', justifyContent: 'center',
                            cursor: 'pointer', opacity: 0.8, transition: 'color 0.1s'
                          }}
                          onMouseEnter={e => e.currentTarget.style.color = 'var(--red)'}
                          onMouseLeave={e => e.currentTarget.style.color = 'var(--text3)'}
                        >
                          ✕
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        )}

        {/* Tab 2: Full Character Sheet */}
        {activeTab === 'sheet' && (
          <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>
            <FieldTextArea label="PHYSICAL APPEARANCE" value={data.appearance || ''} onChange={v => update('appearance', v)} placeholder="Describe their looks, clothing style, scars, and details..." />
            <FieldTextArea label="CORE PERSONALITY & TRAITS" value={data.personality || ''} onChange={v => update('personality', v)} placeholder="How do they behave? alignment, flaws, values..." />
            <FieldTextArea label="ABILITIES, WEAPONS & POWERS" value={data.powers || ''} onChange={v => update('powers', v)} placeholder="What can they do? Weapons equipped, spells, magic..." />
            <FieldTextArea label="BACKSTORY & BIOGRAPHY" value={data.backstory || ''} onChange={v => update('backstory', v)} placeholder="Where did they come from? History with the main character..." />
          </div>
        )}
      </div>

      {/* Save Button */}
      <button
        onClick={() => {
          if (!data.name.trim()) { alert('Name is required.'); return }
          onSave(data)
        }}
        style={{
          width: '100%', background: 'var(--gold-dim)',
          border: '1px solid var(--gold)', color: 'var(--text)',
          padding: '12px', borderRadius: 'var(--radius)',
          fontFamily: 'Cinzel, serif', fontSize: '11px',
          letterSpacing: '1.5px', cursor: 'pointer',
          flexShrink: 0,
        }}
      >
        SAVE CHARACTER
      </button>
    </div>
  )
}

function FieldInput({ label, value, onChange, placeholder }: { label: string, value: string, onChange: (v: string) => void, placeholder?: string }) {
  return (
    <div style={{ marginBottom: '16px' }}>
      <label style={{ fontFamily: 'Cinzel, serif', fontSize: '10px', color: 'var(--text2)', letterSpacing: '1.5px', display: 'block', marginBottom: '6px' }}>
        {label}
      </label>
      <input
        value={value}
        onChange={e => onChange(e.target.value)}
        placeholder={placeholder}
        style={{
          width: '100%', background: 'var(--surface2)',
          border: '1px solid var(--border2)', borderRadius: 'var(--radius)',
          padding: '10px 14px', color: 'var(--text)',
          fontFamily: 'Crimson Pro, serif', fontSize: '15px',
          outline: 'none', transition: 'border-color 0.2s',
        }}
        onFocus={e => e.target.style.borderColor = 'var(--gold)'}
        onBlur={e => e.target.style.borderColor = 'var(--border2)'}
      />
    </div>
  )
}

function FieldTextArea({ label, value, onChange, placeholder }: { label: string, value: string, onChange: (v: string) => void, placeholder?: string }) {
  return (
    <div>
      <label style={{ fontFamily: 'Cinzel, serif', fontSize: '10px', color: 'var(--text2)', letterSpacing: '1.5px', display: 'block', marginBottom: '6px' }}>
        {label}
      </label>
      <textarea
        value={value}
        onChange={e => onChange(e.target.value)}
        placeholder={placeholder}
        rows={4}
        style={{
          width: '100%', background: 'var(--surface2)',
          border: '1px solid var(--border2)', borderRadius: 'var(--radius)',
          padding: '10px 14px', color: 'var(--text)',
          fontFamily: 'Crimson Pro, serif', fontSize: '15px',
          outline: 'none', transition: 'border-color 0.2s',
          resize: 'vertical', lineHeight: 1.6
        }}
        onFocus={e => e.target.style.borderColor = 'var(--gold)'}
        onBlur={e => e.target.style.borderColor = 'var(--border2)'}
      />
    </div>
  )
}

// ─── ROSTER ENCYCLOPEDIA GRID (Matches your paint sketch!) ─────────────────────

export default function RosterManager({ roster, onSave, onBack }: RosterManagerProps) {
  const [chars, setChars] = useState<Character[]>(roster)
  const [editing, setEditing] = useState<{ char: Character; index: number | null } | null>(null)
  const [hovered, setHovered] = useState<string | null>(null)

  function handleSaveChar(char: Character) {
    let updated: Character[]
    if (editing!.index !== null) {
      updated = chars.map((c, i) => i === editing!.index ? char : c)
    } else {
      updated = [...chars, { ...char, id: 'char_' + Date.now() }]
    }
    setChars(updated)
    onSave(updated)
    setEditing(null)
  }

  function handleDelete(e: React.MouseEvent, index: number) {
    e.stopPropagation() // Stop click from opening editor
    if (!confirm(`Remove ${chars[index].name}?`)) return
    const updated = chars.filter((_, i) => i !== index)
    setChars(updated)
    onSave(updated)
  }

  function newCharacter(): Character {
    return { id: '', name: '', role: '', color: COLORS[0], avatar: null, appearance: '', personality: '', powers: '', backstory: '' }
  }

  if (editing) {
    return (
      <CharacterSheet
        character={editing.char}
        onSave={handleSaveChar}
        onBack={() => setEditing(null)}
        isNew={editing.index === null}
      />
    )
  }

  return (
    <div style={{ display: 'flex', flexDirection: 'column', height: '100%', minHeight: '500px' }}>

      {/* Header */}
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '24px', flexShrink: 0 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
          <button
            onClick={onBack}
            style={{
              background: 'transparent', border: '1px solid var(--border2)',
              color: 'var(--text2)', padding: '6px 12px',
              borderRadius: 'var(--radius)', fontFamily: 'Cinzel, serif',
              fontSize: '11px', letterSpacing: '1px', cursor: 'pointer',
            }}
          >
            ← BACK
          </button>
          <div style={{ fontFamily: 'Cinzel, serif', fontSize: '16px', color: 'var(--gold)', letterSpacing: '2px' }}>
            ROSTER ENCYCLOPEDIA
          </div>
        </div>
        <button
          onClick={() => setEditing({ char: newCharacter(), index: null })}
          style={{
            background: 'var(--gold-dim)', border: '1px solid var(--gold)',
            color: 'var(--text)', padding: '8px 16px',
            borderRadius: 'var(--radius)', fontFamily: 'Cinzel, serif',
            fontSize: '11px', letterSpacing: '1px', cursor: 'pointer',
          }}
        >
          + ADD NPC
        </button>
      </div>

      {/* Encyclopedia CSS Grid! Matches the boxes in your Paint sketch */}
      {chars.length === 0 ? (
        <div style={{ textAlign: 'center', color: 'var(--text3)', fontStyle: 'italic', fontSize: '14px', marginTop: '40px' }}>
          No characters discovered yet. Add your first manual NPC, or meet them naturally in the campaign story!
        </div>
      ) : (
        <div style={{ 
          flex: 1, 
          overflowY: 'auto', 
          display: 'grid', 
          
          // ─── UPDATED GRID COLUMNS & JUSTIFICATION (CENTER-ALIGNED ENCYCLOPEDIA!) ───
          gridTemplateColumns: 'repeat(auto-fit, 130px)', // Strict 130px columns [2]
          justifyContent: 'center',                       // Centers the grid cards horizontally [2]
          gap: '20px',                                    // Elegant spacing between cards
          
          paddingRight: '6px',
          paddingBottom: '10px'
        }}>
          {chars.map((char, i) => (
            <div
              key={char.id || i}
              onMouseEnter={() => setHovered(char.id || String(i))}
              onMouseLeave={() => setHovered(null)}
              onClick={() => setEditing({ char, index: i })}
              style={{
                position: 'relative',
                width: '100%',
                aspectRatio: '2 / 3',           // Vertical portrait ratio!
                background: 'var(--surface3)',
                
                // ─── SHORTHAND BORDER CONFLICT FIX (SILENCES CONSOLE WARNINGS!) ───
                borderTop: `1px solid ${hovered === (char.id || String(i)) ? 'var(--gold)' : 'var(--border)'}`,
                borderLeft: `1px solid ${hovered === (char.id || String(i)) ? 'var(--gold)' : 'var(--border)'}`,
                borderRight: `1px solid ${hovered === (char.id || String(i)) ? 'var(--gold)' : 'var(--border)'}`,
                borderBottom: `4px solid ${char.color}`, // Dynamic rarity/accent color strip!
                
                borderRadius: 'var(--radius)',
                overflow: 'hidden',
                transition: 'all 0.15s ease-in-out',
                cursor: 'pointer',
              }}
            >
              {char.avatar ? (
                <img src={char.avatar} style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
              ) : (
                <div style={{ 
                  height: '100%', display: 'flex', alignItems: 'center', justifyContent: 'center', 
                  fontSize: '36px', fontFamily: 'Cinzel, serif', color: char.color, opacity: 0.35 
                }}>
                  {char.name[0] || '?'}
                </div>
              )}

              {/* Text Overlays with Dark Bottom Gradient */}
              <div style={{
                position: 'absolute', bottom: 0, insetInline: 0,
                background: 'linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.5) 60%, transparent 100%)',
                padding: '10px', display: 'flex', flexDirection: 'column', justifyContent: 'flex-end',
              }}>
                <div style={{ fontFamily: 'Cinzel, serif', fontSize: '11px', color: 'var(--text)', letterSpacing: '0.5px', fontWeight: 600, whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                  {char.name}
                </div>
                <div style={{ fontSize: '10px', color: 'var(--text3)', fontStyle: 'italic', marginTop: '2px', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                  {char.role || 'Discovered NPC'}
                </div>
              </div>

              {/* Delete Button (Only visible on hover) */}
              {hovered === (char.id || String(i)) && (
                <button
                  onClick={e => handleDelete(e, i)}
                  style={{
                    position: 'absolute', top: '6px', right: '6px',
                    background: 'rgba(0,0,0,0.7)', border: '1px solid rgba(255,255,255,0.15)',
                    color: 'var(--text3)', fontSize: '10px', cursor: 'pointer',
                    width: '20px', height: '20px', borderRadius: '50%',
                    display: 'flex', alignItems: 'center', justifyContent: 'center',
                    transition: 'all 0.15s',
                  }}
                  onMouseEnter={e => (e.currentTarget.style.color = 'var(--red)')}
                  onMouseLeave={e => (e.currentTarget.style.color = 'var(--text3)')}
                >
                  ✕
                </button>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  )
}
</file>

<file path="src/components/SettingsModal.tsx">
import { useState } from 'react'
import type { Campaign, PlayerAppearance, PlayerPersonality, PlayerPowers } from '../types'
import Step2Universe from './wizard/Step2Universe'
import Step3Appearance from './wizard/Step3Appearance'
import Step4Personality from './wizard/Step4Personality'
import Step5Powers from './wizard/Step5Powers'
import RosterManager from './RosterManager'

interface SettingsModalProps {
  campaign: Campaign
  onSave: (updated: Campaign) => void
  onClose: () => void
  initialSection?: Section 
  theme: string             // NEW: Active theme state
  onThemeChange: (t: string) => void // NEW: Callback to swap themes
}

type Section = 
  | 'menu' 
  | 'campaign-menu' 
  | 'characters-menu' 
  | 'main-character-menu' 
  | 'campaign-details' 
  | 'instructions' 
  | 'appearance' 
  | 'personality' 
  | 'powers' 
  | 'roster'
  | 'atmosphere'
  | 'chronicle'

export default function SettingsModal({ campaign, onSave, onClose, initialSection = 'menu', theme, onThemeChange }: SettingsModalProps) {
  const [section, setSection] = useState<Section>(initialSection) 
  const [hovered, setHovered] = useState<string | null>(null)

  // ─── Fixed Hooks ────────────────────────────────────────────────────────────
  const [newLog, setNewLog] = useState('')
  const [editIndex, setEditIndex] = useState<number | null>(null)
  const [editValue, setEditValue] = useState('')

  // ─── Sub-section handlers ───────────────────────────────────────────────────

  function handleSaveCampaign(setting: string, dmInstructions: string, worldChanges: string) {
    onSave({ ...campaign, setting, dmInstructions, worldChanges })
    setSection('campaign-menu')
  }

  function handleSaveInstructions(instructions: string) {
    onSave({ ...campaign, dmInstructions: instructions })
    setSection('campaign-menu')
  }

  function handleSaveAppearance(appearance: PlayerAppearance) {
    onSave({ ...campaign, player: { ...campaign.player, appearance } })
    setSection('main-character-menu') 
  }

  function handleSavePersonality(personality: PlayerPersonality) {
    onSave({ ...campaign, player: { ...campaign.player, personality } })
    setSection('main-character-menu') 
  }

  function handleSavePowers(powers: PlayerPowers) {
    onSave({ ...campaign, player: { ...campaign.player, powers } })
    setSection('main-character-menu') 
  }

  function handleSaveRoster(roster: Campaign['roster']) {
    onSave({ ...campaign, roster })
  }

  // ─── Sub-sections ───────────────────────────────────────────────────────────

  if (section === 'campaign-details') {
    return (
      <FullScreenWrap onClose={onClose}>
        <Step2Universe 
          initialSetting={campaign.setting} 
          initialInstructions={campaign.dmInstructions} 
          initialWorldChanges={campaign.worldChanges || ''} 
          onNext={handleSaveCampaign} 
          onBack={() => setSection('campaign-menu')} 
          hideInstructions={true}
        />
      </FullScreenWrap>
    )
  }

  if (section === 'instructions') {
    return <FullScreenWrap onClose={onClose}><InstructionsEditor initialValue={campaign.dmInstructions} onSave={handleSaveInstructions} onBack={() => setSection('campaign-menu')} /></FullScreenWrap>
  }

  if (section === 'appearance') {
    return <FullScreenWrap onClose={onClose}><Step3Appearance initialValue={campaign.player.appearance} onNext={handleSaveAppearance} onBack={() => setSection('main-character-menu')} /></FullScreenWrap>
  }

  if (section === 'personality') {
    return <FullScreenWrap onClose={onClose}><Step4Personality initialValue={campaign.player.personality} onNext={handleSavePersonality} onBack={() => setSection('main-character-menu')} /></FullScreenWrap>
  }

  if (section === 'powers') {
    return <FullScreenWrap onClose={onClose}><Step5Powers initialValue={campaign.player.powers} onNext={handleSavePowers} onBack={() => setSection('main-character-menu')} /></FullScreenWrap>
  }

  if (section === 'roster') {
    return (
      <FullScreenWrap onClose={onClose}>
        <div style={{ height: '100vh', background: 'var(--bg)', display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'flex-start', overflowY: 'auto', padding: '40px 24px' }}>
          <div style={{ width: '100%', maxWidth: '1000px', background: 'var(--surface)', border: '1px solid var(--border)', borderRadius: '12px', padding: '36px' }}>
            <RosterManager
              roster={campaign.roster}
              onSave={handleSaveRoster}
              onBack={() => setSection('characters-menu')}
            />
          </div>
        </div>
      </FullScreenWrap>
    )
  }

  // ─── UPDATED: ATMOSPHERE PANE WITH THEME SELECTOR ───
  if (section === 'atmosphere') {
    const backgrounds = campaign.backgrounds || []
    const active = campaign.activeBackground

    function handleImageUpload(e: React.ChangeEvent<HTMLInputElement>) {
      const file = e.target.files?.[0]
      if (!file) return

      const reader = new FileReader()
      reader.onload = (ev) => {
        const img = new Image()
        img.onload = () => {
          const canvas = document.createElement('canvas')
          let { width, height } = img
          const max = 1920
          if (width > height && width > max) { height *= max / width; width = max }
          else if (height > max) { width *= max / height; height = max }
          
          canvas.width = width
          canvas.height = height
          const ctx = canvas.getContext('2d')
          ctx?.drawImage(img, 0, 0, width, height)
          
          const compressedBase64 = canvas.toDataURL('image/jpeg', 0.6) 
          const newBgList = [...backgrounds, compressedBase64]
          onSave({ ...campaign, backgrounds: newBgList, activeBackground: compressedBase64 })
        }
        img.src = ev.target?.result as string
      }
      reader.readAsDataURL(file)
    }

    return (
      <FullScreenWrap onClose={onClose}>
        <div style={{ height: '100vh', display: 'flex', flexDirection: 'column', alignItems: 'center', padding: '40px 24px', overflowY: 'auto' }}>
          <div style={{ width: '100%', maxWidth: '800px', background: 'var(--surface)', border: '1px solid var(--border)', borderRadius: '12px', padding: '36px' }}>
            
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '24px' }}>
              <button onClick={() => setSection('menu')} style={{ background: 'transparent', border: '1px solid var(--border2)', color: 'var(--text2)', padding: '6px 14px', borderRadius: 'var(--radius)', fontFamily: 'Cinzel, serif', fontSize: '11px', cursor: 'pointer' }}>← BACK</button>
              <div style={{ fontFamily: 'Cinzel, serif', fontSize: '18px', color: 'var(--gold)', letterSpacing: '2px' }}>ATMOSPHERE & VISUALS</div>
            </div>

           {/* ─── UPDATED: 4-THEME SELECTION IN IN-GAME ATMOSPHERE ─── */}
            <div style={{ marginBottom: '28px', paddingBottom: '20px', borderBottom: '1px solid var(--border)' }}>
              <div style={{ fontFamily: 'Cinzel, serif', fontSize: '10px', color: 'var(--text3)', letterSpacing: '2px', marginBottom: '10px' }}>
                SYSTEM HUD THEME COLOR
              </div>
              
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, 1fr)', gap: '6px' }}>
                {[
                  { name: 'destiny', label: 'Destiny' },
                  { name: 'crimson', label: 'Crimson' },
                  { name: 'true-soul', label: 'True Soul' },
                  { name: 'requiem', label: 'Requiem' }
                ].map(t => (
                  <button
                    key={t.name}
                    onClick={() => onThemeChange(t.name)}
                    style={{
                      padding: '10px 2px',
                      background: theme === t.name ? 'var(--gold-dim)' : 'var(--surface2)',
                      border: `1px solid ${theme === t.name ? 'var(--gold)' : 'var(--border)'}`,
                      borderRadius: 'var(--radius)',
                      color: theme === t.name ? 'var(--gold)' : 'var(--text3)',
                      fontFamily: 'Cinzel, serif',
                      fontSize: '9px',
                      letterSpacing: '0.5px',
                      cursor: 'pointer',
                      transition: 'all 0.15s',
                      textTransform: 'uppercase',
                      fontWeight: theme === t.name ? 'bold' : 'normal'
                    }}
                  >
                    {t.label}
                  </button>
                ))}
              </div>
            </div>

            <div style={{ marginBottom: '24px' }}>
              <div style={{ fontFamily: 'Cinzel, serif', fontSize: '10px', color: 'var(--text3)', letterSpacing: '2px', marginBottom: '10px' }}>
                WALLPAPER DIRECTORY
              </div>
              <div onClick={() => document.getElementById('bg-upload')?.click()} style={{ width: '100%', padding: '30px', background: 'var(--surface2)', border: '2px dashed var(--border2)', borderRadius: 'var(--radius)', textAlign: 'center', cursor: 'pointer', transition: 'border-color 0.2s' }} onMouseEnter={e => e.currentTarget.style.borderColor = 'var(--gold)'} onMouseLeave={e => e.currentTarget.style.borderColor = 'var(--border2)'}>
                <span style={{ fontFamily: 'Cinzel, serif', fontSize: '14px', color: 'var(--gold)' }}>+ UPLOAD NEW WALLPAPER</span>
                <div style={{ fontSize: '12px', color: 'var(--text3)', marginTop: '8px' }}>Images are automatically compressed to save storage limits</div>
              </div>
              <input type="file" id="bg-upload" accept="image/*" style={{ display: 'none' }} onChange={handleImageUpload} />
            </div>

            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(220px, 1fr))', gap: '16px' }}>
              <div onClick={() => onSave({ ...campaign, activeBackground: null })} style={{ aspectRatio: '16/9', background: 'var(--bg)', border: !active ? '2px solid var(--gold)' : '1px solid var(--border)', borderRadius: 'var(--radius)', cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', fontFamily: 'Cinzel, serif', fontSize: '12px', color: !active ? 'var(--gold)' : 'var(--text2)' }}>
                DEFAULT BLACK
              </div>

              {backgrounds.map((bg, i) => (
                <div key={i} onClick={() => onSave({ ...campaign, activeBackground: bg })} style={{ position: 'relative', aspectRatio: '16/9', borderRadius: 'var(--radius)', overflow: 'hidden', cursor: 'pointer', border: active === bg ? '2px solid var(--gold)' : '2px solid transparent' }}>
                  <img src={bg} alt="bg" style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                  {active === bg && <div style={{ position: 'absolute', bottom: '8px', right: '8px', background: 'var(--gold)', color: '#fff', padding: '2px 8px', borderRadius: '4px', fontSize: '10px', fontFamily: 'Cinzel, serif' }}>ACTIVE</div>}
                  <button onClick={(e) => {
                    e.stopPropagation()
                    const newBgs = backgrounds.filter((_, idx) => idx !== i)
                    onSave({ ...campaign, backgrounds: newBgs, activeBackground: active === bg ? null : active })
                  }} style={{ position: 'absolute', top: '8px', right: '8px', background: 'rgba(0,0,0,0.7)', border: '1px solid rgba(255,255,255,0.2)', color: 'var(--text)', width: '24px', height: '24px', borderRadius: '50%', cursor: 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '12px' }}>✕</button>
                </div>
              ))}
            </div>

          </div>
        </div>
      </FullScreenWrap>
    )
  }

  // ─── CHRONICLE LEDGER COMPONENT ───
  if (section === 'chronicle') {
    const timeline = campaign.timeline || []

    function handleAdd() {
      if (!newLog.trim()) return
      const updated = [...timeline, newLog.trim()]
      onSave({ ...campaign, timeline: updated })
      setNewLog('')
    }

    function handleDelete(idx: number) {
      if (!confirm('Are you sure you want to remove this fact from the timeline? The DM will instantly forget it.')) return
      const updated = timeline.filter((_, i) => i !== idx)
      onSave({ ...campaign, timeline: updated })
    }

    // Double Check: Ensure references don't leak
    function startEdit(idx: number, val: string) {
      setEditIndex(idx)
      setEditValue(val)
    }

    function saveEdit(idx: number) {
      if (!editValue.trim()) return
      const updated = timeline.map((line, i) => i === idx ? editValue.trim() : line)
      onSave({ ...campaign, timeline: updated })
      setEditIndex(null)
    }

    function handleExportCapsule() {
      const capsule = {
        capsuleVersion: 'soul_v1',
        campaignName: `${campaign.name} (Season 2)`, 
        setting: campaign.setting,
        dmInstructions: campaign.dmInstructions,
        player: campaign.player,
        roster: campaign.roster,
        timeline: campaign.timeline || [],
        backgrounds: campaign.backgrounds || [],
        activeBackground: campaign.activeBackground || null,
        worldChanges: campaign.worldChanges || '', 
      }

      const fileData = JSON.stringify(capsule, null, 2)
      const blob = new Blob([fileData], { type: 'application/json' })
      const url = URL.createObjectURL(blob)
      const link = document.createElement('a')
      link.href = url
      link.download = `Soul_Capsule_${campaign.name.replace(/\s+/g, '_')}.json`
      document.body.appendChild(link)
      link.click()
      document.body.removeChild(link)
      URL.revokeObjectURL(url)
    }

    return (
      <FullScreenWrap onClose={onClose}>
        <div style={{ height: '100vh', display: 'flex', flexDirection: 'column', alignItems: 'center', padding: '40px 24px', overflowY: 'auto' }}>
          <div style={{ width: '100%', maxWidth: '800px', background: 'var(--surface)', border: '1px solid var(--border)', borderRadius: '12px', padding: '36px' }}>
            
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '24px' }}>
              <div style={{ display: 'flex', gap: '12px' }}>
                <button onClick={() => setSection('campaign-menu')} style={{ background: 'transparent', border: '1px solid var(--border2)', color: 'var(--text2)', padding: '6px 14px', borderRadius: 'var(--radius)', fontFamily: 'Cinzel, serif', fontSize: '11px', cursor: 'pointer' }}>← BACK</button>
                <button 
                  onClick={handleExportCapsule} 
                  style={{ 
                    background: 'var(--gold-dim)', border: '1px solid var(--gold)', 
                    color: 'var(--text)', padding: '6px 14px', borderRadius: 'var(--radius)', 
                    fontFamily: 'Cinzel, serif', fontSize: '11px', cursor: 'pointer' 
                  }}
                >
                  🌀 EXPORT SOUL CAPSULE
                </button>
              </div>
              <div style={{ fontFamily: 'Cinzel, serif', fontSize: '18px', color: 'var(--gold)', letterSpacing: '2px' }}>STORY CHRONICLE LEDGER</div>
            </div>

            <div style={{ fontSize: '13px', color: 'var(--text3)', fontStyle: 'italic', marginBottom: '24px', lineHeight: 1.65 }}>
              This is the complete list of factual, chronological timeline logs compiled automatically by the DM (or entered by you). 
              The AI DM reads these facts directly as un-erasable memory context. You can edit, add, or prune facts to manage the game's canon!
            </div>

            <div style={{ display: 'flex', gap: '10px', marginBottom: '28px' }}>
              <input
                value={newLog}
                onChange={e => setNewLog(e.target.value)}
                onKeyDown={e => e.key === 'Enter' && handleAdd()}
                placeholder="Manually add a key story detail... (e.g. Barry lost his left arm in combat)"
                style={{
                  flex: 1, background: 'var(--surface2)', border: '1px solid var(--border2)',
                  borderRadius: 'var(--radius)', padding: '12px 16px', color: 'var(--text)',
                  fontSize: '15px', outline: 'none'
                }}
                onFocus={e => e.target.style.borderColor = 'var(--gold)'}
                onBlur={e => e.target.style.borderColor = 'var(--border2)'}
              />
              <button
                onClick={handleAdd}
                style={{
                  background: 'var(--gold-dim)', border: '1px solid var(--gold)',
                  color: 'var(--text)', padding: '0 24px', borderRadius: 'var(--radius)',
                  fontFamily: 'Cinzel, serif', fontSize: '11px', letterSpacing: '1px'
                }}
              >
                ADD TO CANON
              </button>
            </div>

            {timeline.length === 0 ? (
              <div style={{ textAlign: 'center', color: 'var(--text3)', fontStyle: 'italic', padding: '40px 0' }}>
                The chronicle ledger is currently empty. Play the game to let the DM log events automatically, or write your first manual canon entry above!
              </div>
            ) : (
              <div style={{ display: 'flex', flexDirection: 'column', gap: '10px' }}>
                {timeline.map((line, i) => (
                  <div key={i} style={{
                    background: 'var(--surface2)', border: '1px solid var(--border)',
                    borderRadius: 'var(--radius)', padding: '14px 18px',
                    display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: '16px'
                  }}>
                    {editIndex === i ? (
                      <div style={{ display: 'flex', gap: '10px', flex: 1 }}>
                        <input
                          value={editValue}
                          onChange={e => setEditValue(e.target.value)}
                          onKeyDown={e => e.key === 'Enter' && saveEdit(i)}
                          style={{
                            flex: 1, background: 'var(--surface3)', border: '1px solid var(--border2)',
                            borderRadius: 'var(--radius)', padding: '8px 12px', color: 'var(--text)',
                            fontSize: '15px', outline: 'none'
                          }}
                          autoFocus
                        />
                        <button onClick={() => saveEdit(i)} style={{ background: 'var(--gold-dim)', border: '1px solid var(--gold)', color: 'var(--text)', padding: '6px 14px', borderRadius: 'var(--radius)', fontSize: '10px', fontFamily: 'Cinzel, serif' }}>SAVE</button>
                        <button onClick={() => setEditIndex(null)} style={{ background: 'transparent', border: '1px solid var(--border2)', color: 'var(--text2)', padding: '6px 14px', borderRadius: 'var(--radius)', fontSize: '10px', fontFamily: 'Cinzel, serif' }}>CANCEL</button>
                      </div>
                    ) : (
                      <>
                        <div style={{ flex: 1, fontSize: '15px', color: 'var(--text)', display: 'flex', gap: '10px' }}>
                          <span style={{ color: 'var(--gold)' }}>•</span>
                          <span>{line}</span>
                        </div>
                        <div style={{ display: 'flex', gap: '8px', flexShrink: 0 }}>
                          <button onClick={() => startEdit(i, line)} style={{ background: 'transparent', border: '1px solid var(--border2)', color: 'var(--text2)', padding: '6px 12px', borderRadius: 'var(--radius)', fontSize: '10px', fontFamily: 'Cinzel, serif', cursor: 'pointer' }}>✏ EDIT</button>
                          <button onClick={() => handleDelete(i)} style={{ background: 'transparent', border: '1px solid var(--border2)', color: 'var(--text3)', padding: '6px 12px', borderRadius: 'var(--radius)', fontSize: '10px', fontFamily: 'Cinzel, serif', cursor: 'pointer' }} onMouseEnter={e => e.currentTarget.style.color = 'var(--red)'} onMouseLeave={e => e.currentTarget.style.color = 'var(--text3)'}>✕ REMOVE</button>
                        </div>
                      </>
                    )}
                  </div>
                ))}
              </div>
            )}

          </div>
        </div>
      </FullScreenWrap>
    )
  }

  // ─── Sub-Menus ──────────────────────────────────────────────────────────────

  if (section === 'campaign-menu') {
    return (
      <MenuWrap title="EDIT CAMPAIGN" subtitle={campaign.name} onBack={() => setSection('menu')} onClose={onClose}>
        <MenuButton id="details" label="⚔ Edit World details" hint="Update the setting, era, genre, or genre details" onClick={() => setSection('campaign-details')} hovered={hovered} setHovered={setHovered} />
        <MenuButton id="inst" label="📜 Edit DM Instructions" hint="Update writing style, tone, rules, and pacing instructions" onClick={() => setSection('instructions')} hovered={hovered} setHovered={setHovered} />
        <MenuButton id="chron" label="📜 Edit Chronicle Timeline" hint="Manage key chronological developments, major injuries, and canon history" onClick={() => setSection('chronicle')} hovered={hovered} setHovered={setHovered} />
      </MenuWrap>
    )
  }

  if (section === 'characters-menu') {
    return (
      <MenuWrap title="EDIT CHARACTERS" subtitle={campaign.name} onBack={() => setSection('menu')} onClose={onClose}>
        <MenuButton id="main-char" label="👤 Edit Main Character" hint="Stats, physical appearance, personality, and special abilities" onClick={() => setSection('main-character-menu')} hovered={hovered} setHovered={setHovered} />
        <MenuButton id="rost" label="👥 Edit NPC Roster" hint="Manage your companion directory, allies, and enemies" onClick={() => setSection('roster')} hovered={hovered} setHovered={setHovered} />
      </MenuWrap>
    )
  }

  if (section === 'main-character-menu') {
    return (
      <MenuWrap title="EDIT MAIN CHARACTER" subtitle={campaign.name} onBack={() => setSection('characters-menu')} onClose={onClose}>
        <MenuButton id="app" label="◈ Appearance" hint="Edit character portrait, race, age, height, clothing style" onClick={() => setSection('appearance')} hovered={hovered} setHovered={setHovered} />
        <MenuButton id="pers" label="✦ Personality" hint="Edit moral alignment, traits, backstory, dark secrets" onClick={() => setSection('personality')} hovered={hovered} setHovered={setHovered} />
        <MenuButton id="pow" label="⚡ Powers" hint="Edit character class, subclass, active weapons, special skills" onClick={() => setSection('powers')} hovered={hovered} setHovered={setHovered} />
      </MenuWrap>
    )
  }

  // ─── Main Menu ──────────────────────────────────────────────────────────────

  return (
    <MenuWrap title="SETTINGS" subtitle={campaign.name} onClose={onClose}>
      <MenuButton id="edit-camp" label="⚔ Edit Campaign" hint="Manage world setting, genre details, and DM behaviour manuals" onClick={() => setSection('campaign-menu')} hovered={hovered} setHovered={setHovered} />
      <MenuButton id="edit-chars" label="👥 Edit Characters" hint="Manage player character sheets, abilities, portraits, and NPCs" onClick={() => setSection('characters-menu')} hovered={hovered} setHovered={setHovered} />
      <MenuButton id="edit-atmos" label="🌌 Edit Atmosphere" hint="Change chat backgrounds and visuals" onClick={() => setSection('atmosphere')} hovered={hovered} setHovered={setHovered} />
    </MenuWrap>
  )
}

// ─── Helper UI Components ──────────────────────────────────────────────────────

interface MenuButtonProps {
  id: string
  label: string
  hint: string
  onClick: () => void
  hovered: string | null
  setHovered: (id: string | null) => void
}

function MenuButton({ id, label, hint, onClick, hovered, setHovered }: MenuButtonProps) {
  const isHovered = hovered === id
  return (
    <button
      onClick={onClick}
      onMouseEnter={() => setHovered(id)}
      onMouseLeave={() => setHovered(null)}
      style={{
        display: 'flex', alignItems: 'center', justifyContent: 'space-between',
        width: '100%',
        padding: '14px 18px',
        background: isHovered ? 'var(--surface2)' : 'transparent',
        border: `1px solid ${isHovered ? 'var(--border2)' : 'var(--border)'}`,
        borderRadius: 'var(--radius)', cursor: 'pointer',
        transition: 'all 0.15s', textAlign: 'left',
        marginBottom: '8px',
      }}
    >
      <div>
        <div style={{ fontFamily: 'Cinzel, serif', fontSize: '12px', color: 'var(--text)', letterSpacing: '1px' }}>{label}</div>
        <div style={{ fontSize: '12px', color: 'var(--text3)', fontStyle: 'italic', marginTop: '3px' }}>{hint}</div>
      </div>
      <div style={{ color: 'var(--text3)', fontSize: '14px' }}>→</div>
    </button>
  )
}

interface MenuWrapProps {
  title: string
  subtitle: string
  children: React.ReactNode
  onBack?: () => void
  onClose: () => void
}

function MenuWrap({ title, subtitle, children, onBack, onClose }: MenuWrapProps) {
  return (
    <div style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.85)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 200 }}>
      <div style={{ background: 'var(--surface)', border: '1px solid var(--border2)', borderRadius: '14px', padding: '32px', width: '500px', maxHeight: '90vh', overflowY: 'auto' }}>
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '24px' }}>
          <div>
            <div style={{ fontFamily: 'Cinzel, serif', fontSize: '18px', color: 'var(--gold)', letterSpacing: '2px' }}>{title}</div>
            <div style={{ fontFamily: 'Cinzel, serif', fontSize: '11px', color: 'var(--text3)', letterSpacing: '1px', marginTop: '4px' }}>{subtitle}</div>
          </div>
          <button
            onClick={onClose}
            style={{ background: 'transparent', border: '1px solid var(--border2)', color: 'var(--text2)', width: '32px', height: '32px', borderRadius: '50%', fontSize: '14px', cursor: 'pointer' }}
          >✕</button>
        </div>
        {children}
        {onBack && (
          <button
            onClick={onBack}
            style={{
              width: '100%', padding: '12px', marginTop: '16px',
              background: 'transparent', border: '1px solid var(--border2)', borderRadius: 'var(--radius)',
              color: 'var(--text2)', fontFamily: 'Cinzel, serif', fontSize: '11px', letterSpacing: '1.5px',
              cursor: 'pointer', transition: 'all 0.2s',
            }}
            onMouseEnter={e => e.currentTarget.style.borderColor = 'var(--gold)'}
            onMouseLeave={e => e.currentTarget.style.borderColor = 'var(--border2)'}
          >
            ← BACK
          </button>
        )}
      </div>
    </div>
  )
}

function FullScreenWrap({ children, onClose }: { children: React.ReactNode, onClose: () => void }) {
  return (
    <div style={{ position: 'fixed', inset: 0, zIndex: 200, background: 'var(--bg)', overflowY: 'auto' }}>
      <button
        onClick={onClose}
        style={{
          position: 'fixed', top: '16px', right: '20px',
          background: 'var(--surface)', border: '1px solid var(--border2)',
